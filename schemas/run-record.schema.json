{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pathrule.io/schemas/benchmark-run-record-v1.json",
  "title": "Pathrule benchmark run record",
  "type": "object",
  "required": [
    "schema_version",
    "cell",
    "status",
    "started_at",
    "completed_at",
    "prompt_results",
    "scores",
    "transcript_path",
    "artifact_hashes"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "cell": {
      "type": "object",
      "required": ["cell_id", "config_hash"],
      "properties": {
        "cell_id": { "type": "string", "minLength": 1 },
        "config_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "status": {
      "enum": ["completed", "failed", "timed_out", "interrupted", "invalid"]
    },
    "prompt_results": { "type": "array" },
    "scores": { "type": "object" },
    "transcript_path": { "type": ["string", "null"] },
    "artifact_hashes": { "type": "object" }
  }
}
